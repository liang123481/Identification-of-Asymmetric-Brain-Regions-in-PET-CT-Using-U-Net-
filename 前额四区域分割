def put_line_by_detect(graph_path):#通过计算图片非背景区域的中心，作过该点的直线，之后通过旋转直线，寻找左右两侧像素对称程度最高的那一条，画出该直线作为大脑的中轴线
    graph = cv2.imread(graph_path)
    if graph_path is None:#读这个文件出错
        print(f"该文件读取错误: {graph_path}")
        return  None, None, None

    huidu_graph=cv2.cvtColor(graph, cv2.COLOR_BGR2GRAY)# RGB转灰度
    hsv = cv2.cvtColor(graph, cv2.COLOR_BGR2HSV)  # BGR转HSV
    changed_binary = (huidu_graph > BLACK_THRESH).astype(np.uint8)#根据阈值筛选背景和有用信息转0-1二值
    if np.sum(changed_binary) == 0:
        print(f"无有用信息图片")
        return None, None, None
    shape = graph.shape
    height = shape[0]
    weight = shape[1]
    #计算大脑的中心，去二值为1的区域的所有xy坐标的均值作为中心
    x, y = np.where(changed_binary == 1)
    mid_x, mid_y = int(np.mean(x)), int(np.mean(y))
    #检测最外层轮廓
    lunkuo, _ = cv2.findContours(changed_binary, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    if not lunkuo:
        print(f"无轮廓")
        return None, None, None
    best_angle, max_score = 0, -1
    #开始搜索角度，从限定角度查找
    angle_range = (-20, 20)
    per_angle=1
    #遍历指定角度范围，计算每个角度下目标区域的对称得分，找到最佳对称角度
    for angle in range(angle_range[0], angle_range[1] + 1, per_angle):
        theta = radians(angle)
        cos_t, sin_t = cos(theta), sin(theta)
        y_grid, x_grid = np.mgrid[0:height, 0:weight]
        distance = (x_grid - mid_x) * cos_t + (y_grid - mid_y) * sin_t
        left_mask = (distance < 0) & (changed_binary == 1)
        right_mask = (distance >= 0) & (changed_binary == 1)
        left_count, right_count = np.sum(left_mask), np.sum(right_mask)
        if left_count == 0 or right_count == 0:
            continue

        right_ys, right_xs = np.where(right_mask)
        sym_x = np.round(right_xs - 2 * ((right_xs - mid_x) * cos_t + (right_ys - mid_y) * sin_t) * cos_t).astype(int)
        sym_y = np.round(right_ys - 2 * ((right_xs - mid_x) * cos_t + (right_ys - mid_y) * sin_t) * sin_t).astype(int)
        sym_x, sym_y = np.clip(sym_x, 0, weight - 1), np.clip(sym_y, 0, height - 1)

        matches = 0
        #统计颜色匹配的对称点数量，核心
        for rx, ry, sx, sy in zip(right_xs, right_ys, sym_x, sym_y):
            if color_similarity(hsv[ry, rx], hsv[sy, sx], color_sim):
                matches += 1

        score = matches / right_count if right_count else 0
        if score > max_score:
            max_score, best_angle = score, angle#保存答案

    theta = radians(best_angle)
    x1 = int(mid_x- weight * sin(theta))
    y1 = int(mid_y + weight * cos(theta))
    x2 = int(mid_x + weight * sin(theta))
    y2 = int(mid_y - weight * cos(theta))
    red_line = [(x1, y1), (x2, y2)]
    jiaodian=find_line_lunkuo_intersections(lunkuo,red_line)
    top, bottom = find_half_closest_points(jiaodian, mid_x, mid_y, height)
    line_points = {}
    if top and bottom:
        line_points['segment'] = (top, bottom)

        # 计算上1/3点
        upper_third_point = get_up_oneinthree_point(top, bottom)

        # 计算线段角度
        segment_angle = segment_angle1(top, bottom)

        # 生成垂线
        perp_line = extentline(segment_angle, upper_third_point, (height, weight))

        # 找到垂线与轮廓的交点
        contour_intersections = find_line_lunkuo_intersections(lunkuo, perp_line)

        # 找到左右半边最近点
        left_closest, right_closest = get_left_right_close(contour_intersections, upper_third_point, weight)

        # 计算移动点
        left_moved = move_to_three(left_closest, upper_third_point,
                                              TARGET_DISTANCE_PX) if left_closest else None
        right_moved = move_to_three(right_closest, upper_third_point,
                                               TARGET_DISTANCE_PX) if right_closest else None

        if left_moved and right_moved:
            line_points['arc'] = (left_moved, right_moved, upper_third_point)

    return line_points, (weight, height), graph_path

ARC_EXTRA_EXTEND = 150  # 圆弧额外延伸像素
ARC_RADIUS_SCALE = 0.8  # 圆弧半径缩放因子
#画圆弧
def draw_concave(graph, left_point, right_point, third_point, color, thickness):
    lx, ly = left_point
    rx, ry = right_point
    tx, ty = third_point
    img_height, img_weight = graph.shape[:2]

    # 1. 计算弦的基础参数
    mid_x = (lx + rx) // 2
    mid_y = (ly + ry) // 2
    chord_dx = rx - lx
    chord_dy = ry - ly

    # 2. 强制圆心在上方向
    perp_dir1 = (-chord_dy, chord_dx)  # 垂直方向1
    perp_dir2 = (chord_dy, -chord_dx)  # 垂直方向2

    # 选择向上的方向（y分量为负）
    if perp_dir1[1] < perp_dir2[1]:
        perp_dir = perp_dir1
    else:
        perp_dir = perp_dir2

    # 3. 计算圆弧半径
    chord_len = sqrt(chord_dx ** 2 + chord_dy ** 2)
    base_radius = max(int(chord_len * ARC_RADIUS_SCALE), 200)
    radius = base_radius + ARC_EXTRA_EXTEND

    # 确保半径足够大以触及所有边界
    max_required_radius = max(
        sqrt(mid_x ** 2 + mid_y ** 2),
        sqrt((img_weight - mid_x) ** 2 + mid_y ** 2),
        sqrt(mid_x ** 2 + (img_height - mid_y) ** 2),
        sqrt((img_weight - mid_x) ** 2 + (img_height - mid_y) ** 2)
    )

    if radius < max_required_radius:
        radius = int(max_required_radius + 100)

    # 4. 计算圆心坐标（确保在上）
    center_dist = sqrt(radius ** 2 - (chord_len / 2) ** 2)
    perp_len = sqrt(perp_dir[0] ** 2 + perp_dir[1] ** 2) or 1
    ux = perp_dir[0] / perp_len
    uy = perp_dir[1] / perp_len

    # 计算初始圆心
    cx = int(mid_x + ux * center_dist)
    cy = int(mid_y + uy * center_dist)

    # 确保圆心在图像上方
    if cy > img_height * 0.5:  # 超过中线视为下方
        cx = int(mid_x - ux * center_dist)
        cy = int(mid_y - uy * center_dist)

    # 5. 获取所有边界交点
    boundary_intersections = circle_bianjie_intersections(cx, cy, radius, img_weight, img_height)

    # 6. 筛选有效交点
    valid_intersections = []
    for (x, y) in boundary_intersections:
        vec = (x - mid_x, y - mid_y)
        if perp_dir[0] * vec[0] + perp_dir[1] * vec[1] > 0:
            valid_intersections.append((x, y))

    # 7. 去重
    unique_valid = []
    s = set()
    for p in valid_intersections:
        key = (round(p[0]), round(p[1]))
        if key not in s:
            s.add(key)
            unique_valid.append(p)
    valid_intersections = unique_valid

    if len(valid_intersections) < 2:
        line_start, line_end = draw_line_to_boundary(graph, left_point, right_point, color, thickness)
        return ("line", line_start, line_end, None, None)

    # 角度排序
    def centerangle(p):
        return atan2(p[1] - cy, p[0] - cx)

    valid_intersections.sort(key=centerangle)
    start = valid_intersections[0]
    end = valid_intersections[-1]

    # 计算角度
    start_angle = degrees(centerangle(start))
    end_angle = degrees(centerangle(end))

    # 1绘制圆弧
    cv2.ellipse(
        graph,
        center=(cx, cy),
        axes=(radius, radius),
        angle=0,
        startAngle=start_angle,
        endAngle=end_angle,
        color=color,
        thickness=thickness,
        lineType=cv2.LINE_AA
    )

    return (cx, cy, radius, start_angle, end_angle)

def seg_graph(graph, start, end, arc_params):
    height, weight = graph.shape[:2]

    # 创建区域掩码
    region_mask = np.zeros((height, weight), dtype=np.uint8)

    # 检查是否是直线而不是圆弧
    if arc_params[0] == "line":
        # 处理直线情况
        _, arc_start, arc_end, _, _ = arc_params

        # 为每个像素分配区域
        for y in range(height):
            for x in range(weight):
                # 判断在主直线的哪一侧
                line_side = (end[0] - start[0]) * (y - start[1]) - (end[1] - start[1]) * (
                        x - start[0])

                # 判断在弧线替代直线的哪一侧
                arc_side = (arc_end[0] - arc_start[0]) * (y - arc_start[1]) - (arc_end[1] - arc_start[1]) * (
                        x - arc_start[0])

                # 分配区域
                if line_side > 0:  # 主直线左侧
                    if arc_side < 0:  # 弧线替代直线下方
                        region_mask[y, x] = 1  # 上左
                    else:  # 弧线替代直线上方
                        region_mask[y, x] = 3  # 下左
                else:  # 主直线右侧
                    if arc_side < 0:  # 弧线替代直线下方
                        region_mask[y, x] = 2  # 上右
                    else:  # 弧线替代直线上方
                        region_mask[y, x] = 4  # 下右
        return region_mask

    # 处理正常圆弧情况
    cx, cy, radius, start_angle, end_angle = arc_params

    for y in range(height):
        for x in range(weight):
            # 判断在直线的哪一侧
            line_side = (end[0] - start[0]) * (y - start[1]) - (end[1] - start[1]) * (
                    x - start[0])

            # 判断在弧线的哪一侧（使用实际绘制的弧线）
            dx = x - cx
            dy = y - cy
            point_angle = degrees(atan2(dy, dx))
            point_radius = sqrt(dx ** 2 + dy ** 2)

            # 标准化角度到0-360范围
            if point_angle < 0:
                point_angle += 360
            if start_angle < 0:
                start_angle_norm = start_angle + 360
            else:
                start_angle_norm = start_angle
            if end_angle < 0:
                end_angle_norm = end_angle + 360
            else:
                end_angle_norm = end_angle

            # 判断点是否在弧线范围内
            if start_angle_norm <= end_angle_norm:
                in_arc_range = start_angle_norm <= point_angle <= end_angle_norm
            else:
                in_arc_range = point_angle >= start_angle_norm or point_angle <= end_angle_norm

            # 判断点在弧线的哪一侧（基于半径比较）
            arc_side = point_radius <= radius

            # 分配区域
            if line_side > 0:  # 直线左侧
                if arc_side and in_arc_range:  # 弧线内侧且在范围内
                    region_mask[y, x] = 1  # 区域1: 上左
                else:  # 弧线外侧
                    region_mask[y, x] = 3  # 区域3: 下左
            else:  # 直线右侧
                if arc_side and in_arc_range:  # 弧线内侧且在范围内
                    region_mask[y, x] = 2  # 区域2: 上右
                else:  # 弧线外侧
                    region_mask[y, x] = 4  # 区域4: 下右

    return region_mask

