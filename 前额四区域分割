def circle_bianjie_intersections(cx, cy, r, graph_w, graph_h):
    intersections = []

    # 检查四条边界
    bianjie = [
        (0, None),  # 左边界 x=0
        (graph_w - 1, None),  # 右边界 x=img_w-1
        (None, 0),  # 上边界 y=0
        (None, graph_h - 1)  # 下边界 y=img_h-1
    ]

    for border in bianjie:
        x_const, y_const = border

        if x_const is not None:  # 垂直边界
            # 解方程: (x_const - cx)^2 + (y - cy)^2 = r^2
            dx = x_const - cx
            if abs(dx) <= r:
                dy = sqrt(r ** 2 - dx ** 2)
                y1 = cy + dy
                y2 = cy - dy
                if 0 <= y1 <= graph_h - 1:
                    intersections.append((x_const, int(y1)))
                if 0 <= y2 <= graph_h - 1:
                    intersections.append((x_const, int(y2)))

        elif y_const is not None:  # 水平边界
            # 解方程: (x - cx)^2 + (y_const - cy)^2 = r^2
            dy = y_const - cy
            if abs(dy) <= r:
                dx = sqrt(r ** 2 - dy ** 2)
                x1 = cx + dx
                x2 = cx - dx
                if 0 <= x1 <= graph_w - 1:
                    intersections.append((int(x1), y_const))
                if 0 <= x2 <= graph_w - 1:
                    intersections.append((int(x2), y_const))

    return intersections


def draw_line_to_boundary(img, top, bottom, color, thickness):
    graph_height, graph_weight = img.shape[:2]

    # 获取直线与边界的交点
    boundary_intersections = get_jiaodian_line_bianjie(top, bottom, graph_weight, graph_height)

    # 确保有两个交点
    if len(boundary_intersections) >= 2:
        # 选择距离最远的两个点，确保直线贯穿整个图像
        max_dist = 0
        best_pair = (boundary_intersections[0], boundary_intersections[1])

        for i in range(len(boundary_intersections)):
            for j in range(i + 1, len(boundary_intersections)):
                p1, p2 = boundary_intersections[i], boundary_intersections[j]
                dist = sqrt((p1[0] - p2[0]) ** 2 + (p1[1] - p2[1]) ** 2)
                if dist > max_dist:
                    max_dist = dist
                    best_pair = (p1, p2)

        start_point, end_point = best_pair
    else:
        # 如果没有足够交点，延长直线
        angle = segment_angle1(top, bottom)
        rad = radians(angle)
        extend_len = max(graph_weight, graph_height) * 3
        start_point = (int(top[0] - extend_len * cos(rad)),
                       int(top[1] - extend_len * sin(rad)))
        end_point = (int(bottom[0] + extend_len * cos(rad)),
                     int(bottom[1] + extend_len * sin(rad)))

    # 绘制直线
    cv2.line(
        img,
        (int(start_point[0]), int(start_point[1])),
        (int(end_point[0]), int(end_point[1])),
        color,
        thickness,
        lineType=cv2.LINE_AA
    )

    return start_point, end_point

def draw_on_mask(mask, region_mask):
    # 转换为三通道图像
    if len(mask.shape) == 2:
        result = cv2.cvtColor(mask, cv2.COLOR_GRAY2BGR)
    else:
        result = mask.copy()

    # 创建带透明度的区域覆盖层
    overlay = result.copy()

    # 为每个区域上色
    for id in range(1, 5):
        color = r_color[id - 1][:3]  # 只取BGR部分
        pixels = (region_mask == id)
        overlay[pixels] = color

    # 混合原图和覆盖层（保持掩码可见）
    alpha = 0.4  # 透明度
    result = cv2.addWeighted(overlay, alpha, result, 1 - alpha, 0)

    return result

# 提取分割的四个区域为单独图像
def save4regions(mask, region_mask, graph_name):
    height, weight = mask.shape[:2]

    # 创建纯黑色背景
    black_bg = np.zeros((height, weight, 3), dtype=np.uint8)

    for id in range(1, 5):
        # 创建该区域的掩码
        region_only = np.zeros((height, weight), dtype=np.uint8)
        region_pixels = (region_mask == id)
        region_only[region_pixels] = 255

        # 在原掩码上提取该区域
        if len(mask.shape) == 2:
            # 单通道掩码
            masked = cv2.bitwise_and(mask, mask, mask=region_only)
            # 转换为三通道以便保存为彩色图像
            masked = cv2.cvtColor(masked, cv2.COLOR_GRAY2BGR)
        else:
            # 已经是三通道
            masked = cv2.bitwise_and(mask, mask, mask=region_only)

        # 在黑色背景上显示该区域
        region_black = black_bg.copy()
        region_black[region_pixels] = masked[region_pixels]

        # 保存区域图像
        region_name = r_name[id - 1]
        region_folder = os.path.join(region, region_name)
        path = os.path.join(region_folder, f"{graph_name}_{region_name}.png")
        cv2.imwrite(path, region_black)

        print(f"保存{id} ({region_name}): {path}")

SEGMENT_LINE_WIDTH = 4  # 紫色线段宽度
ARC_THICKNESS = 3  # 圆弧线宽
ARC_COLOR = (255, 165, 0)  # 凹圆弧颜色（橙色）
def draw_lines_on_mask(mask, line_points, original_size, mask_size, graph_name):
    result_mask = mask.copy()
    original_mask = mask.copy()  # 保存原始掩码用于区域分割

    # 转换为三通道以绘制彩色线条
    if len(result_mask.shape) == 2:
        result_mask = cv2.cvtColor(result_mask, cv2.COLOR_GRAY2BGR)
    else:
        result_mask = mask.copy()

    # 计算缩放比例
    orig_w, orig_h = original_size
    mask_w, mask_h = mask_size
    scale_x = mask_w / orig_w
    scale_y = mask_h / orig_h

    def scale_point(point):
        x, y = point
        return (int(x * scale_x), int(y * scale_y))

    # 绘制紫色线段（延伸至边界）并获取实际绘制的端点
    line_start, line_end = None, None
    if 'segment' in line_points:
        top_closest, bottom_closest = line_points['segment']
        top_scaled = scale_point(top_closest)
        bottom_scaled = scale_point(bottom_closest)
        line_start, line_end = draw_line_to_boundary(result_mask, top_scaled, bottom_scaled, (128, 0, 128),
                                                     SEGMENT_LINE_WIDTH)

    # 绘制橙色凹圆弧并获取弧线参数
    arc_params = None
    if 'arc' in line_points:
        left_moved, right_moved, upper_third_point = line_points['arc']
        left_scaled = scale_point(left_moved)
        right_scaled = scale_point(right_moved)
        third_scaled = scale_point(upper_third_point)
        arc_params = draw_concave(result_mask, left_scaled, right_scaled, third_scaled, ARC_COLOR,
                                                  ARC_THICKNESS)

    # 使用实际绘制的线条分割图像为4个区域
    region_mask = None
    if line_start is not None and arc_params is not None:
        region_mask = seg_graph(result_mask, line_start, line_end, arc_params)

        # 保存四个区域的单独图像
        save4regions(original_mask, region_mask, graph_name)

        # 在掩码上绘制彩色区域（保持掩码可见）
        result_mask = draw_on_mask(result_mask, region_mask)

    return result_mask, region_mask, original_mask

def save_regions_to_original(original_graph, mask, original_mask, img_name, original_size):
    if original_graph is None or mask is None or original_mask is None:
        return

    # 获取尺寸
    orig_w, orig_h = original_size
    h_orig, w_orig = original_graph.shape[:2]
    h_mask, w_mask = mask.shape[:2]

    # 将原始掩码调整到与原图相同尺寸
    if h_mask != h_orig or w_mask != w_orig:
        original_mask_resized = cv2.resize(original_mask, (w_orig, h_orig), interpolation=cv2.INTER_NEAREST)
        region_mask_resized = cv2.resize(mask, (w_orig, h_orig), interpolation=cv2.INTER_NEAREST)
    else:
        original_mask_resized = original_mask
        region_mask_resized = mask

    # 确保掩码是二值的（白色部分为255）
    _, original_mask_binary = cv2.threshold(original_mask_resized, 127, 255, cv2.THRESH_BINARY)

    # 为每个区域映射到原图
    for region_id in range(1, 5):
        # 创建该区域的掩码（区域掩码中对应区域）
        region_only = np.zeros((h_orig, w_orig), dtype=np.uint8)
        region_pixels = (region_mask_resized == region_id)
        region_only[region_pixels] = 255

        # 计算交集：区域掩码 AND 原始掩码的白色部分
        final_mask = cv2.bitwise_and(region_only, original_mask_binary)
        black_bg = np.zeros_like(original_graph)

        # 将原图与最终掩码结合（只在掩码白色区域显示原图）
        if len(original_graph.shape) == 3:
            final_mask_3channel = cv2.cvtColor(final_mask, cv2.COLOR_GRAY2BGR)
        else:
            final_mask_3channel = final_mask

        region_on_original = cv2.bitwise_and(original_graph, final_mask_3channel)

        region_name = r_name[region_id - 1]
        origin_folder = os.path.join(origin, region_name)
        origin_path = os.path.join(origin_folder, f"{img_name}_{region_name}.png")
        cv2.imwrite(origin_path, region_on_original)

        print(f"保存原图{region_id} ({region_name}): {origin_path}")

def subtract(mask1, mask2):
    if mask1.shape != mask2.shape:
        mask2 = cv2.resize(
            mask2,
            (mask1.shape[1], mask1.shape[0]),
            interpolation=cv2.INTER_NEAREST
        )

    overlap = (mask1 == 255) & (mask2 == 255)

    result = mask1.copy()
    result[overlap] = 0

    return result

def load_and_standardize_mask(path):
    mask = cv2.imread(path, cv2.IMREAD_UNCHANGED)
    if mask is None:

        print(f"无法读取掩码：{path}")

        return None

    if mask.ndim == 3 and mask.shape[2] == 4:
        alpha = mask[:, :, 3]

        mask = np.where(alpha > 0, 255, 0).astype(np.uint8)

    else:
        if mask.ndim == 3:

            mask = cv2.cvtColor(mask, cv2.COLOR_BGR2GRAY)
        mask = np.where(mask > 0, 255, 0).astype(np.uint8)
    return mask

SUPPORTED_EXTENSIONS = ('.jpg', '.jpeg', '.png', '.bmp', '.gif')


def process_single_image(original_img_path, mask1_folder, mask2_folder, output_folder):
    img_name = os.path.splitext(os.path.basename(original_img_path))[0]
    print(f"\n正在处理: {img_name}")

    # 检测线条
    line_points, original_size, _ = put_line_by_detect(original_img_path)
    if not line_points or 'segment' not in line_points or 'arc' not in line_points:
        print(f"未检测到完整线条: {img_name}")
        return

    # 加载原图用于映射
    original_img = cv2.imread(original_img_path)
    if original_img is None:
        print(f"无法加载原图: {original_img_path}")
        return

    # 处理掩码
    mask1_path = os.path.join(mask1_folder, f"{img_name}.png")
    mask2_path = os.path.join(mask2_folder, f"{img_name}.png")
    if not os.path.exists(mask1_path) or not os.path.exists(mask2_path):
        print(f"掩码缺失: {img_name}")
        return

    mask1 = load_and_standardize_mask(mask1_path)
    mask2 = load_and_standardize_mask(mask2_path)
    if mask1 is None or mask2 is None:
        print(f"掩码加载失败: {img_name}")
        return

    subtracted_mask = subtract(mask1, mask2)
    # 绘制线条并填充区域
    mask_size = (subtracted_mask.shape[1], subtracted_mask.shape[0])
    final_result, region_mask, original_mask = draw_lines_on_mask(subtracted_mask, line_points, original_size, mask_size, img_name)
    output_path = os.path.join(output_folder, f"{img_name}_with_regions.png")
    cv2.imwrite(output_path, final_result)
    print(f"结果保存: {output_path}")

    #将区域映射回原图（只显示掩码白色部分）
    if region_mask is not None:
        save_regions_to_original(original_img, region_mask, original_mask, img_name, original_size)

def find_half_closest_points(intersections, cx, cy, graph_height):
    if not intersections:
        return None, None

    img_midline = graph_height / 2
    inter_data = []
    for (x, y) in intersections:
        dist = sqrt((x - cx) ** 2 + (y - cy) ** 2)
        inter_data.append((x, y, dist, y))

    top_half_candidates = [p for p in inter_data if p[3] <= img_midline]
    top_closest = min(top_half_candidates, key=lambda x: x[2])[0:2] if top_half_candidates else None

    bottom_half_candidates = [p for p in inter_data if p[3] > img_midline]
    bottom_closest = min(bottom_half_candidates, key=lambda x: x[2])[0:2] if bottom_half_candidates else None

    return top_closest, bottom_closest

def segment_intersection(a1, a2, b1, b2):
    x1, y1 = a1
    x2, y2 = a2
    x3, y3 = b1
    x4, y4 = b2
    denom = (x1 - x2) * (y3 - y4) - (y1 - y2) * (x3 - x4)
    if denom == 0:
        return None
    t = ((x1 - x3) * (y3 - y4) - (y1 - y3) * (x3 - x4)) / denom
    u = -((x1 - x2) * (y1 - y3) - (y1 - y2) * (x1 - x3)) / denom
    if 0 <= t <= 1 and 0 <= u <= 1:
        x = int(round(x1 + t * (x2 - x1)))
        y = int(round(y1 + t * (y2 - y1)))
        return (x, y)
    return None

def deal(input_folder, mask1_folder, mask2_folder, output_folder):
    # 获取文件夹中所有支持的图片文件
    graph_files = [
        f for f in os.listdir(input_folder)
        if f.lower().endswith(SUPPORTED_EXTENSIONS)
    ]

    if not graph_files:
        print(f"{input_folder} 中未找到任何图片文件")
        return

    total = len(graph_files)
    print(f"找到{total}个图片文件")

    for i, filename in enumerate(graph_files, 1):
        print(f"\n处理文件 {i}/{total} ")
        path = os.path.join(input_folder, filename)
        process_single_image(path, mask1_folder, mask2_folder, output_folder)

    print(f"\n完成！")
    print(f"结果在: {output_folder}")
    print(f"四个区域分别保存在:{region}")



