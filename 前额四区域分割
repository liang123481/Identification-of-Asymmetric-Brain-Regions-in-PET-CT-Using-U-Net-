def get_jiaodian_line_bianjie(p1, p2, weight, height):
    x1, y1 = p1
    x2, y2 = p2
    intersections = []

    # 直线方程参数(ax + by + c = 0)
    a = y2 - y1
    b = x1 - x2
    c = x2 * y1 - x1 * y2

    # 检查所有边界
    bianjie = [
        (0, 0, 0, height - 1),  # 左边界
        (weight - 1, 0, weight - 1, height - 1),  #右边界
        (0, 0, weight - 1, 0),  # 上边界
        (0, height - 1, weight - 1, height - 1)  #下边界
    ]

    for border in bianjie:
        bx1, by1, bx2, by2 = border
        # 计算交点
        if bx1==bx2:  # 垂直边界
            if b != 0:
                x = bx1
                y = (-a*x -c) / b
                if 0 <= y <= height-1:
                    intersections.append((int(x), int(y)))
        else:  # 水平边界
            if a != 0:
                y= by1
                x= (-b* y-c) / a
                if 0 <= x <= weight - 1:
                    intersections.append((int(x), int(y)))

    # 去重
    unique_inter = []
    s = set()
    for p in intersections:
        key = (round(p[0]), round(p[1]))
        if key not in s:
            s.add(key)
            unique_inter.append(p)

    return unique_inter
#量化判断两个像素在 HSV 色彩空间中的相似度
def color_similarity(hsv1, hsv2, threshold):
    h1, s1, v1 = map(int, hsv1)
    h2, s2, v2 = map(int, hsv2)
    h_diff = abs(h1 - h2)
    h_diff = min(h_diff, 180 - h_diff)
    s_diff = abs(s1 - s2)
    v_diff = abs(v1 - v2)
    h_norm = (h_diff / 90) * 100
    s_norm = (s_diff / 255) * 100
    v_norm = (v_diff / 255) * 100
    return (0.5 * h_norm + 0.25 * s_norm + 0.25 * v_norm) <= threshold

def segment_angle1(top, bottom):
    dx = bottom[0] - top[0]
    dy = bottom[1] - top[1]
    return degrees(atan2(dy, dx))

def get_up_oneinthree_point(top, bottom):
    tx, ty = top
    bx, by = bottom
    x = int(tx+ (bx-tx) /3)
    y = int(ty + (by-ty) /3)
    return (x, y)

def move_to_three(start, target, step_dist):
    x0, y0 = start
    x1, y1 = target

    # 计算方向向量和两点距离
    dx = x1 - x0
    dy = y1 - y0
    dist = sqrt(dx ** 2 + dy ** 2)

    # 防止除零（如果两点几乎重合，直接返回起点）
    if dist < 1e-6:
        return (x0, y0)

    # 实际移动距离（不超过两点间距）
    actual_dist = min(step_dist, dist)
    nx = dx / dist
    ny = dy / dist
    # 计算新坐标（取整）
    x = int(x0 + nx * actual_dist)
    y = int(y0 + ny * actual_dist)

    return (x, y)


def get_left_right_close(intersections, third_point, graph_weight):
    if not intersections:
        return None, None

    graph_mid_x = graph_weight / 2
    tx, ty = third_point

    inter_data = []
    for (x, y) in intersections:
        dist = sqrt((x - tx) ** 2 + (y - ty) ** 2)
        inter_data.append((x, y, dist))

    right_candidates = [p for p in inter_data if p[0] > graph_mid_x]
    right_closest = min(right_candidates, key=lambda x: x[2])[0:2] if right_candidates else None


    left_candidates = [p for p in inter_data if p[0] <= graph_mid_x]
    left_closest = min(left_candidates, key=lambda x: x[2])[0:2] if left_candidates else None

    return left_closest, right_closest


def extentline(segment_angle, point, graph_shape):
    height, weight = graph_shape
    max_extend = int(min(weight, height) * 3.0)  # 增大延长距离
    chuizhi = radians(segment_angle) + pi / 2#计算一条线段的垂直方向角度

    x, y = point
    x1 = int(x - max_extend * cos(chuizhi))
    y1 = int(y - max_extend * sin(chuizhi))
    x2 = int(x + max_extend * cos(chuizhi))
    y2 = int(y + max_extend * sin(chuizhi))

    return (x1, y1), (x2, y2)

def find_line_lunkuo_intersections(contours, line):
    intersections = []
    line_start, line_end = line
    for cnt in contours:
        for i in range(len(cnt)):
            p1 = tuple(cnt[i][0])
            p2 = tuple(cnt[(i + 1) % len(cnt)][0])
            inter = segment_intersection(line_start, line_end, p1, p2)
            if inter:
                intersections.append(inter)
    unique_inter = []
    seen = set()
    for p in intersections:
        key = (p[0], p[1])
        if key not in seen:
            seen.add(key)
            unique_inter.append(p)
    return unique_inter

BLACK_THRESH = 20#判定该区域是背景还是有用信息
color_sim= 30
TARGET_DISTANCE_CM = 0.9  # 目标距离
DPI = 96  # 图像分辨率
CM_TO_PX = DPI / 2.54
